rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Analytics security logic
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    match /analytics/{docId} {
      allow read: if isValidId(docId);
      
      allow create: if isValidId(docId) && 
        (request.resource.data.keys().hasAny(['visits', 'scans']));

      allow update: if isValidId(docId) &&
        (request.resource.data.diff(resource.data).affectedKeys().hasAny(['visits', 'scans']));
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
